# Nome do banco de dados PostgreSQL
SPRING_DATASOURCE_DATABASE=

# URL de conexão JDBC (use localhost para execução local fora do Docker)
SPRING_DATASOURCE_URL=

# Credenciais do banco de dados
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Porta do PostgreSQL exposta no host (mapeada para 5432 no container)
SPRING_DATASOURCE_PORT=

# Porta da aplicação exposta no host (mapeada para 8080 no container)
APP_PORT=

# Perfil Spring ativo — use "dev" para habilitar SQL logging
SPRING_PROFILES_ACTIVE=

# JWT configuration
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION_TIME=15
