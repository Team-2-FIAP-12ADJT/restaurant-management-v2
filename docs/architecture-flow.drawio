        <!-- ===== Legenda ===== -->
        <mxCell id="legend" value="Legenda: azul = fluxo feliz (numerado) · vermelho tracejado = erro (impureza deliberada: handler global, não presenter) · cinza tracejado = implementa (inversão de dependência: interface mora no círculo de dentro, impl no de fora) · caixas tracejadas = interfaces" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
